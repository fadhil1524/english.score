<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>British English Score – Learn & Test</title>

    <!-- ===== CSS ===== -->
    <style>
        /* ---------- RESET & BASE ---------- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --navy: #0b1a33;
            --navy-light: #1a2f4f;
            --blue: #1a6bb0;
            --blue-light: #4a8fc7;
            --gold: #f4b942;
            --gold-light: #fad37a;
            --white: #ffffff;
            --gray: #f0f4f8;
            --gray-dark: #4a5a6a;
            --shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
            --radius: 16px;
            --transition: 0.3s ease;
            --font: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font);
            background: var(--gray);
            color: #1a2a3a;
            line-height: 1.6;
            min-height: 100vh;
        }

        a {
            text-decoration: none;
            color: inherit;
        }
        button {
            cursor: pointer;
            font-family: inherit;
            border: none;
            background: none;
            font-size: 1rem;
        }

        /* ---------- SCROLLBAR ---------- */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--gray);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--blue);
            border-radius: 10px;
        }

        /* ---------- LAYOUT ---------- */
        .app {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px 40px;
        }

        /* ---------- HEADER / NAV ---------- */
        header {
            background: var(--navy);
            color: var(--white);
            padding: 16px 0;
            border-radius: 0 0 var(--radius) var(--radius);
            margin-bottom: 30px;
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        .logo span {
            color: var(--gold);
        }
        .logo small {
            font-size: 0.75rem;
            font-weight: 400;
            opacity: 0.7;
            display: block;
            letter-spacing: 0.5px;
        }

        nav {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }
        nav button {
            padding: 8px 18px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.7);
            transition: var(--transition);
            background: transparent;
            border: 1px solid transparent;
        }
        nav button:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.08);
        }
        nav button.active {
            color: #fff;
            background: var(--gold);
            border-color: var(--gold);
            color: var(--navy);
        }

        .nav-score {
            background: rgba(255, 255, 255, 0.1);
            padding: 6px 16px;
            border-radius: 40px;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .nav-score .num {
            color: var(--gold);
            font-size: 1.1rem;
        }

        /* ---------- SECTIONS ---------- */
        .section {
            display: none;
            animation: fadeUp 0.4s ease;
        }
        .section.active {
            display: block;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ---------- CARDS ---------- */
        .card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 24px 28px;
            box-shadow: var(--shadow);
            margin-bottom: 24px;
            transition: var(--transition);
        }
        .card:hover {
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 8px;
        }
        .card-header h2 {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--navy);
        }
        .card-header .badge {
            background: var(--blue);
            color: #fff;
            padding: 4px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .card-header .badge.gold {
            background: var(--gold);
            color: var(--navy);
        }

        /* ---------- GRID ---------- */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .grid-3 {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        @media (max-width: 860px) {
            .grid-2,
            .grid-3 {
                grid-template-columns: 1fr;
            }
        }

        /* ---------- LEVEL ITEMS ---------- */
        .level-item {
            background: var(--white);
            border-radius: var(--radius);
            padding: 20px 22px;
            box-shadow: var(--shadow);
            border-left: 5px solid var(--blue);
            transition: var(--transition);
            cursor: pointer;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .level-item:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
        }
        .level-item.completed {
            border-left-color: var(--gold);
        }
        .level-item.locked {
            opacity: 0.5;
            cursor: not-allowed;
            pointer-events: none;
        }

        .level-item .top {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .level-item .title {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--navy);
        }
        .level-item .ceff {
            background: var(--gray);
            padding: 2px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--gray-dark);
        }
        .level-item .desc {
            font-size: 0.9rem;
            color: var(--gray-dark);
        }
        .level-item .progress-bar {
            width: 100%;
            height: 6px;
            background: var(--gray);
            border-radius: 10px;
            overflow: hidden;
            margin-top: 6px;
        }
        .level-item .progress-bar .fill {
            height: 100%;
            background: var(--blue);
            border-radius: 10px;
            transition: width 0.6s ease;
        }
        .level-item .progress-bar .fill.gold {
            background: var(--gold);
        }

        .level-item .status-icon {
            font-size: 1.2rem;
        }

        /* ---------- LESSON VIEW ---------- */
        .lesson-content {
            font-size: 1rem;
            line-height: 1.8;
            color: #1a2a3a;
        }
        .lesson-content h3 {
            font-size: 1.3rem;
            color: var(--navy);
            margin: 20px 0 10px;
        }
        .lesson-content h4 {
            font-size: 1.05rem;
            color: var(--navy-light);
            margin: 16px 0 6px;
        }
        .lesson-content ul,
        .lesson-content ol {
            padding-left: 24px;
            margin: 8px 0 12px;
        }
        .lesson-content li {
            margin-bottom: 4px;
        }
        .lesson-content .example {
            background: var(--gray);
            padding: 12px 18px;
            border-radius: 10px;
            margin: 12px 0;
            border-left: 4px solid var(--blue);
            font-style: italic;
        }
        .lesson-content .vocab-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 12px 0;
        }
        @media (max-width: 600px) {
            .lesson-content .vocab-grid {
                grid-template-columns: 1fr;
            }
        }
        .lesson-content .vocab-item {
            background: var(--gray);
            padding: 10px 14px;
            border-radius: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .lesson-content .vocab-item .en {
            font-weight: 600;
            color: var(--navy);
        }
        .lesson-content .vocab-item .id {
            color: var(--gray-dark);
            font-size: 0.9rem;
        }

        /* ---------- QUIZ ---------- */
        .question {
            background: var(--gray);
            border-radius: 12px;
            padding: 18px 22px;
            margin-bottom: 16px;
            transition: var(--transition);
        }
        .question.correct {
            border-left: 5px solid #2ecc71;
            background: #eafaf1;
        }
        .question.wrong {
            border-left: 5px solid #e74c3c;
            background: #fdedec;
        }

        .question .q-text {
            font-weight: 600;
            font-size: 1.05rem;
            margin-bottom: 12px;
            color: var(--navy);
        }

        .options {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .options label {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            background: var(--white);
            border-radius: 10px;
            cursor: pointer;
            transition: var(--transition);
            border: 2px solid transparent;
            font-weight: 500;
        }
        .options label:hover {
            border-color: var(--blue-light);
            background: #f0f7ff;
        }
        .options input[type="radio"] {
            accent-color: var(--blue);
            width: 18px;
            height: 18px;
            flex-shrink: 0;
        }
        .options label.selected {
            border-color: var(--blue);
            background: #e8f0fe;
        }
        .options label.correct-answer {
            border-color: #2ecc71;
            background: #eafaf1;
        }
        .options label.wrong-answer {
            border-color: #e74c3c;
            background: #fdedec;
        }

        .question .explanation {
            margin-top: 12px;
            padding: 12px 16px;
            background: var(--white);
            border-radius: 10px;
            font-size: 0.95rem;
            border-left: 4px solid var(--blue);
            display: none;
        }
        .question .explanation.show {
            display: block;
        }

        .quiz-progress {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 12px;
        }
        .quiz-progress .info {
            font-weight: 600;
            color: var(--gray-dark);
        }
        .quiz-progress .info span {
            color: var(--navy);
            font-size: 1.2rem;
        }

        .btn {
            padding: 10px 28px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--blue);
            color: #fff;
            border: none;
        }
        .btn:hover {
            background: var(--navy-light);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26, 107, 176, 0.3);
        }
        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }
        .btn.gold {
            background: var(--gold);
            color: var(--navy);
        }
        .btn.gold:hover {
            background: var(--gold-light);
        }
        .btn.outline {
            background: transparent;
            color: var(--blue);
            border: 2px solid var(--blue);
        }
        .btn.outline:hover {
            background: var(--blue);
            color: #fff;
        }
        .btn.small {
            padding: 6px 16px;
            font-size: 0.8rem;
        }
        .btn.success {
            background: #2ecc71;
            color: #fff;
        }
        .btn.success:hover {
            background: #27ae60;
        }

        .btn-group {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 16px;
        }

        /* ---------- IELTS ---------- */
        .ielts-section {
            background: linear-gradient(145deg, #0b1a33, #1a2f4f);
            color: #fff;
            border-radius: var(--radius);
            padding: 30px 32px;
            margin-bottom: 24px;
        }
        .ielts-section h2 {
            font-size: 1.8rem;
            color: var(--gold);
            margin-bottom: 6px;
        }
        .ielts-section p {
            opacity: 0.85;
            max-width: 600px;
        }

        .ielts-card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 20px 24px;
            box-shadow: var(--shadow);
            color: #1a2a3a;
            transition: var(--transition);
            cursor: pointer;
        }
        .ielts-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
        }
        .ielts-card .title {
            font-weight: 700;
            font-size: 1.1rem;
            color: var(--navy);
        }
        .ielts-card .desc {
            font-size: 0.9rem;
            color: var(--gray-dark);
            margin: 4px 0 8px;
        }
        .ielts-card .tag {
            display: inline-block;
            background: var(--gray);
            padding: 2px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--gray-dark);
        }

        /* ---------- PROGRESS ---------- */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            gap: 16px;
            margin: 12px 0;
        }
        .stat-item {
            text-align: center;
            padding: 16px 10px;
            background: var(--gray);
            border-radius: 12px;
        }
        .stat-item .num {
            font-size: 2rem;
            font-weight: 700;
            color: var(--navy);
        }
        .stat-item .label {
            font-size: 0.8rem;
            color: var(--gray-dark);
            font-weight: 500;
        }

        .achievement {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            background: var(--gray);
            border-radius: 12px;
            margin-bottom: 10px;
        }
        .achievement .icon {
            font-size: 2rem;
        }
        .achievement .info .title {
            font-weight: 600;
            color: var(--navy);
        }
        .achievement .info .desc {
            font-size: 0.85rem;
            color: var(--gray-dark);
        }
        .achievement.locked {
            opacity: 0.4;
        }

        /* ---------- RESPONSIVE ---------- */
        @media (max-width: 700px) {
            .header-inner {
                flex-direction: column;
                align-items: stretch;
                gap: 8px;
            }
            .logo {
                font-size: 1.2rem;
            }
            nav {
                justify-content: center;
            }
            nav button {
                padding: 6px 14px;
                font-size: 0.8rem;
            }
            .card {
                padding: 18px 16px;
            }
            .ielts-section {
                padding: 20px 18px;
            }
            .quiz-progress {
                flex-direction: column;
                align-items: stretch;
            }
            .btn-group {
                flex-direction: column;
            }
            .btn-group .btn {
                width: 100%;
                justify-content: center;
            }
        }

        @media (max-width: 480px) {
            .app {
                padding: 0 12px 30px;
            }
            .level-item .top {
                flex-wrap: wrap;
            }
            .stat-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        /* ---------- UTILITIES ---------- */
        .text-center {
            text-align: center;
        }
        .mt-8 {
            margin-top: 8px;
        }
        .mt-16 {
            margin-top: 16px;
        }
        .mt-24 {
            margin-top: 24px;
        }
        .mb-8 {
            margin-bottom: 8px;
        }
        .mb-16 {
            margin-bottom: 16px;
        }
        .flex-between {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }
        .gap-8 {
            gap: 8px;
        }
        .gap-12 {
            gap: 12px;
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--gray-dark);
        }
        .empty-state .icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .hidden {
            display: none !important;
        }

        /* toast */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--navy);
            color: #fff;
            padding: 14px 24px;
            border-radius: 12px;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
            font-weight: 500;
            transform: translateY(80px);
            opacity: 0;
            transition: all 0.4s ease;
            z-index: 999;
            max-width: 360px;
        }
        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }
        .toast.success {
            border-left: 5px solid #2ecc71;
        }
        .toast.error {
            border-left: 5px solid #e74c3c;
        }
        .toast.gold {
            border-left: 5px solid var(--gold);
        }
    </style>
</head>
<body>

    <!-- ===== TOAST ===== -->
    <div id="toast" class="toast"></div>

    <!-- ===== HEADER ===== -->
    <header>
        <div class="header-inner">
            <div class="logo">
                <div>
                    🇬🇧 British <span>Score</span>
                    <small>Learn • Test • Succeed</small>
                </div>
            </div>
            <nav id="mainNav">
                <button class="active" data-section="home">🏠 Home</button>
                <button data-section="learn">📚 Learn</button>
                <button data-section="ielts">🎯 IELTS</button>
                <button data-section="progress">📊 Progress</button>
            </nav>
            <div class="nav-score">
                ⭐ Score: <span class="num" id="totalScore">0</span>
            </div>
        </div>
    </header>

    <!-- ===== APP ===== -->
    <div class="app">

        <!-- ===== HOME ===== -->
        <section id="section-home" class="section active">
            <div class="card">
                <div class="card-header">
                    <h2>🇬🇧 Welcome to British Score</h2>
                    <span class="badge gold">Your English Journey</span>
                </div>
                <p style="font-size:1.05rem; margin-bottom:12px;">
                    Master British English from <strong>Beginner (A1)</strong> to <strong>IELTS Ready (C1)</strong>.
                    Complete lessons, take quizzes, and track your progress — all in one place.
                </p>
                <div class="stat-grid" id="homeStats">
                    <div class="stat-item"><div class="num" id="homeLevels">0</div><div class="label">Levels Completed</div></div>
                    <div class="stat-item"><div class="num" id="homeQuizzes">0</div><div class="label">Quizzes Taken</div></div>
                    <div class="stat-item"><div class="num" id="homeScore">0</div><div class="label">Total Score</div></div>
                    <div class="stat-item"><div class="num" id="homeLessons">0</div><div class="label">Lessons Viewed</div></div>
                </div>
                <div class="btn-group">
                    <button class="btn" onclick="navigateTo('learn')">📚 Start Learning</button>
                    <button class="btn gold" onclick="navigateTo('ielts')">🎯 IELTS Prep</button>
                </div>
            </div>

            <div class="card">
                <h3 style="color:var(--navy); margin-bottom:12px;">📈 Your Recent Activity</h3>
                <div id="recentActivity">
                    <p style="color:var(--gray-dark);">Complete your first lesson to see activity here!</p>
                </div>
            </div>
        </section>

        <!-- ===== LEARN ===== -->
        <section id="section-learn" class="section">
            <div class="card">
                <div class="card-header">
                    <h2>📚 Learning Path</h2>
                    <span class="badge">Start from Level 0</span>
                </div>
                <p style="color:var(--gray-dark); margin-bottom:16px;">
                    Follow the path from Beginner to Advanced. Each level has lessons and a final quiz.
                    Unlock the next level by completing the quiz with 60% or higher.
                </p>
                <div id="levelList" class="grid-2"></div>
            </div>
        </section>

        <!-- ===== LEVEL DETAIL (hidden, shown dynamically) ===== -->
        <section id="section-level" class="section">
            <div class="card">
                <div class="flex-between">
                    <div>
                        <button class="btn outline small" onclick="navigateTo('learn')">← Back to Levels</button>
                        <h2 id="levelTitle" style="margin-top:10px; color:var(--navy);"></h2>
                        <p id="levelDesc" style="color:var(--gray-dark);"></p>
                    </div>
                    <span id="levelBadge" class="badge"></span>
                </div>
                <div id="levelLessons" class="mt-16"></div>
                <div id="levelQuiz" class="mt-24"></div>
            </div>
        </section>

        <!-- ===== IELTS ===== -->
        <section id="section-ielts" class="section">
            <div class="ielts-section">
                <h2>🎯 IELTS Preparation</h2>
                <p>Get ready for the IELTS exam with targeted practice. Improve your reading, writing, listening, and speaking skills with British English.</p>
            </div>

            <div class="grid-3" id="ieltsGrid">
                <div class="ielts-card" onclick="openIeltsModule('reading')">
                    <div class="title">📖 Reading</div>
                    <div class="desc">Academic & General Training passages with questions</div>
                    <span class="tag">3 practice tests</span>
                </div>
                <div class="ielts-card" onclick="openIeltsModule('writing')">
                    <div class="title">✍️ Writing</div>
                    <div class="desc">Task 1 & Task 2 with sample answers</div>
                    <span class="tag">5 topics</span>
                </div>
                <div class="ielts-card" onclick="openIeltsModule('listening')">
                    <div class="title">🎧 Listening</div>
                    <div class="desc">Four sections with British English accents</div>
                    <span class="tag">4 practice tests</span>
                </div>
                <div class="ielts-card" onclick="openIeltsModule('speaking')">
                    <div class="title">🗣️ Speaking</div>
                    <div class="desc">Part 1, 2 & 3 with sample answers</div>
                    <span class="tag">8 topics</span>
                </div>
                <div class="ielts-card" onclick="openIeltsModule('vocabulary')">
                    <div class="title">📝 Vocabulary</div>
                    <div class="desc">Academic word list & collocations</div>
                    <span class="tag">200+ words</span>
                </div>
                <div class="ielts-card" onclick="openIeltsModule('grammar')">
                    <div class="title">🔍 Grammar</div>
                    <div class="desc">Complex structures for band 7+</div>
                    <span class="tag">12 topics</span>
                </div>
            </div>

            <!-- IELTS detail area -->
            <div id="ieltsDetail" class="card mt-16" style="display:none;">
                <div class="flex-between">
                    <h3 id="ieltsDetailTitle" style="color:var(--navy);">Module</h3>
                    <button class="btn outline small" onclick="closeIeltsDetail()">✕ Close</button>
                </div>
                <div id="ieltsDetailContent" class="mt-8"></div>
            </div>
        </section>

        <!-- ===== PROGRESS ===== -->
        <section id="section-progress" class="section">
            <div class="card">
                <div class="card-header">
                    <h2>📊 Your Progress</h2>
                    <span class="badge gold">Keep going!</span>
                </div>
                <div class="stat-grid">
                    <div class="stat-item"><div class="num" id="pLevels">0</div><div class="label">Levels Done</div></div>
                    <div class="stat-item"><div class="num" id="pQuizzes">0</div><div class="label">Quizzes</div></div>
                    <div class="stat-item"><div class="num" id="pScore">0</div><div class="label">Total Score</div></div>
                    <div class="stat-item"><div class="num" id="pLessons">0</div><div class="label">Lessons</div></div>
                </div>
                <div style="margin-top:12px;">
                    <div style="display:flex; justify-content:space-between; font-size:0.9rem; color:var(--gray-dark);">
                        <span>Overall Progress</span>
                        <span id="pPercent">0%</span>
                    </div>
                    <div style="width:100%; height:10px; background:var(--gray); border-radius:10px; overflow:hidden; margin-top:4px;">
                        <div id="pBar" style="height:100%; width:0%; background:linear-gradient(90deg, var(--blue), var(--gold)); border-radius:10px; transition:width 0.6s ease;"></div>
                    </div>
                </div>
            </div>

            <div class="card">
                <h3 style="color:var(--navy); margin-bottom:12px;">🏆 Achievements</h3>
                <div id="achievementsList"></div>
            </div>

            <div class="card">
                <h3 style="color:var(--navy); margin-bottom:12px;">📋 Quiz History</h3>
                <div id="quizHistory"></div>
            </div>
        </section>

    </div>


        const LEVELS = [{
            id: 0,
            name: 'Beginner',
            ceff: 'A1',
            desc: 'Start from zero. Learn basic greetings, numbers, and simple sentences.',
            lessons: [{
                title: 'Greetings & Introductions',
                type: 'vocabulary',
                content: `
              <h3>👋 Hello! Let\'s start with basic greetings.</h3>
              <p>In British English, we use different greetings depending on the time of day and formality.</p>
              <div class="vocab-grid">
                <div class="vocab-item"><span class="en">Hello</span> <span class="id">Halo</span></div>
                <div class="vocab-item"><span class="en">Hi</span> <span class="id">Hai</span></div>
                <div class="vocab-item"><span class="en">Good morning</span> <span class="id">Selamat pagi</span></div>
                <div class="vocab-item"><span class="en">Good afternoon</span> <span class="id">Selamat siang</span></div>
                <div class="vocab-item"><span class="en">Good evening</span> <span class="id">Selamat malam</span></div>
                <div class="vocab-item"><span class="en">Good night</span> <span class="id">Selamat tidur</span></div>
              </div>
              <div class="example">
                <strong>Example:</strong> "Good morning, my name is James. What's your name?"
              </div>
              <h4>Introducing yourself</h4>
              <ul>
                <li><strong>My name is...</strong> — Nama saya...</li>
                <li><strong>I'm from...</strong> — Saya dari...</li>
                <li><strong>I'm a student/teacher/engineer.</strong> — Saya seorang pelajar/guru/insinyur.</li>
                <li><strong>Nice to meet you.</strong> — Senang bertemu denganmu.</li>
              </ul>
              <div class="example">
                <strong>Dialogue:</strong><br>
                A: "Hello, I'm Sarah. What's your name?"<br>
                B: "Hi Sarah, I'm Tom. Nice to meet you!"<br>
                A: "Nice to meet you too, Tom. Where are you from?"<br>
                B: "I'm from London. And you?"<br>
                A: "I'm from Manchester."
              </div>
            `
            }, {
                title: 'Numbers & Time',
                type: 'vocabulary',
                content: `
              <h3>🔢 Numbers and telling time in British English</h3>
              <p>Let's learn numbers 1-20 and how to tell the time.</p>
              <div class="vocab-grid">
                <div class="vocab-item"><span class="en">one</span> <span class="id">satu</span></div>
                <div class="vocab-item"><span class="en">two</span> <span class="id">dua</span></div>
                <div class="vocab-item"><span class="en">three</span> <span class="id">tiga</span></div>
                <div class="vocab-item"><span class="en">four</span> <span class="id">empat</span></div>
                <div class="vocab-item"><span class="en">five</span> <span class="id">lima</span></div>
                <div class="vocab-item"><span class="en">six</span> <span class="id">enam</span></div>
                <div class="vocab-item"><span class="en">seven</span> <span class="id">tujuh</span></div>
                <div class="vocab-item"><span class="en">eight</span> <span class="id">delapan</span></div>
                <div class="vocab-item"><span class="en">nine</span> <span class="id">sembilan</span></div>
                <div class="vocab-item"><span class="en">ten</span> <span class="id">sepuluh</span></div>
                <div class="vocab-item"><span class="en">eleven</span> <span class="id">sebelas</span></div>
                <div class="vocab-item"><span class="en">twelve</span> <span class="id">dua belas</span></div>
                <div class="vocab-item"><span class="en">thirteen</span> <span class="id">tiga belas</span></div>
                <div class="vocab-item"><span class="en">fourteen</span> <span class="id">empat belas</span></div>
                <div class="vocab-item"><span class="en">fifteen</span> <span class="id">lima belas</span></div>
                <div class="vocab-item"><span class="en">sixteen</span> <span class="id">enam belas</span></div>
                <div class="vocab-item"><span class="en">seventeen</span> <span class="id">tujuh belas</span></div>
                <div class="vocab-item"><span class="en">eighteen</span> <span class="id">delapan belas</span></div>
                <div class="vocab-item"><span class="en">nineteen</span> <span class="id">sembilan belas</span></div>
                <div class="vocab-item"><span class="en">twenty</span> <span class="id">dua puluh</span></div>
              </div>
              <h4>Telling the time (British style)</h4>
              <ul>
                <li><strong>It's five o'clock.</strong> — Jam 5 tepat.</li>
                <li><strong>It's half past two.</strong> — Jam 2.30.</li>
                <li><strong>It's quarter past seven.</strong> — Jam 7.15.</li>
                <li><strong>It's quarter to nine.</strong> — Jam 8.45.</li>
                <li><strong>It's ten past eleven.</strong> — Jam 11.10.</li>
                <li><strong>It's twenty to six.</strong> — Jam 5.40.</li>
              </ul>
              <div class="example">
                <strong>Tip:</strong> In British English, we use "past" and "to" rather than "after" and "before".
              </div>
            `
            }, {
                title: 'Basic Grammar: To Be',
                type: 'grammar',
                content: `
              <h3>📘 The verb "to be" — am, is, are</h3>
              <p>This is the most important verb in English. Let's learn how to use it.</p>
              <div class="vocab-grid">
                <div class="vocab-item"><span class="en">I am (I'm)</span> <span class="id">Saya</span></div>
                <div class="vocab-item"><span class="en">You are (You're)</span> <span class="id">Kamu</span></div>
                <div class="vocab-item"><span class="en">He is (He's)</span> <span class="id">Dia (laki-laki)</span></div>
                <div class="vocab-item"><span class="en">She is (She's)</span> <span class="id">Dia (perempuan)</span></div>
                <div class="vocab-item"><span class="en">It is (It's)</span> <span class="id">Itu</span></div>
                <div class="vocab-item"><span class="en">We are (We're)</span> <span class="id">Kami</span></div>
                <div class="vocab-item"><span class="en">You are (You're)</span> <span class="id">Kalian</span></div>
                <div class="vocab-item"><span class="en">They are (They're)</span> <span class="id">Mereka</span></div>
              </div>
              <h4>Positive sentences</h4>
              <ul>
                <li>I <strong>am</strong> a student.</li>
                <li>She <strong>is</strong> my friend.</li>
                <li>They <strong>are</strong> from London.</li>
              </ul>
              <h4>Negative sentences</h4>
              <ul>
                <li>I <strong>am not</strong> (I'm not) a teacher.</li>
                <li>He <strong>is not</strong> (isn't) here.</li>
                <li>We <strong>are not</strong> (aren't) ready.</li>
              </ul>
              <h4>Questions</h4>
              <ul>
                <li><strong>Am</strong> I late?</li>
                <li><strong>Is</strong> she your sister?</li>
                <li><strong>Are</strong> they coming?</li>
              </ul>
              <div class="example">
                <strong>Practice dialogue:</strong><br>
                A: "Are you a student?"<br>
                B: "Yes, I am. I'm studying English. Is this your first lesson?"<br>
                A: "Yes, it is. I'm a beginner."<br>
                B: "That's great! We're all beginners here."
              </div>
            `
            }],
            quiz: [{
                question: 'How do you say "Selamat pagi" in British English?',
                options: ['Good morning', 'Good afternoon', 'Good evening', 'Good night'],
                correct: 0,
                explanation: '"Good morning" is used from sunrise until about 12pm.'
            }, {
                question: 'Which number is "fifteen"?',
                options: ['14', '15', '16', '17'],
                correct: 1,
                explanation: 'Fifteen = 15. (Fourteen = 14, Sixteen = 16)'
            }, {
                question: 'What is the correct form: "She ___ a doctor."',
                options: ['am', 'is', 'are', 'be'],
                correct: 1,
                explanation: 'Use "is" with he, she, it.'
            }, {
                question: 'How do you say "Jam 7.15" in British English?',
                options: ['It\'s seven fifteen', 'It\'s quarter past seven', 'It\'s half past seven', 'It\'s quarter to seven'],
                correct: 1,
                explanation: '"Quarter past seven" = 7.15 in British English.'
            }, {
                question: '"Nice to meet you" is used when...',
                options: ['You say goodbye', 'You meet someone for the first time', 'You ask for help', 'You say thank you'],
                correct: 1,
                explanation: '"Nice to meet you" is a common greeting when meeting someone for the first time.'
            }]
        }, {
            id: 1,
            name: 'Elementary',
            ceff: 'A2',
            desc: 'Build your vocabulary and start forming longer sentences. Talk about daily routines and past events.',
            lessons: [{
                title: 'Daily Routines',
                type: 'vocabulary',
                content: `
              <h3>⏰ Talking about your daily routine</h3>
              <p>Learn common verbs and phrases to describe your day.</p>
              <div class="vocab-grid">
                <div class="vocab-item"><span class="en">wake up</span> <span class="id">bangun</span></div>
                <div class="vocab-item"><span class="en">get up</span> <span class="id">bangun dari tempat tidur</span></div>
                <div class="vocab-item"><span class="en">have breakfast</span> <span class="id">sarapan</span></div>
                <div class="vocab-item"><span class="en">go to work / school</span> <span class="id">pergi bekerja / sekolah</span></div>
                <div class="vocab-item"><span class="en">have lunch</span> <span class="id">makan siang</span></div>
                <div class="vocab-item"><span class="en">finish work</span> <span class="id">selesai bekerja</span></div>
                <div class="vocab-item"><span class="en">go home</span> <span class="id">pulang</span></div>
                <div class="vocab-item"><span class="en">have dinner</span> <span class="id">makan malam</span></div>
                <div class="vocab-item"><span class="en">watch TV</span> <span class="id">menonton TV</span></div>
                <div class="vocab-item"><span class="en">go to bed</span> <span class="id">tidur</span></div>
              </div>
              <h4>Example paragraph</h4>
              <div class="example">
                "I wake up at 7am. I get up and have breakfast at 7.30. I go to work at 8am. I have lunch at 12pm. I finish work at 5pm and go home. I have dinner at 7pm, then I watch TV. I go to bed at 10.30pm."
              </div>
              <p><strong>Tip:</strong> Use the present simple tense for routines and habits.</p>
            `
            }, {
                title: 'Past Simple Tense',
                type: 'grammar',
                content: `
              <h3>⏳ Past Simple Tense</h3>
              <p>Use the past simple to talk about completed actions in the past.</p>
              <h4>Regular verbs: add -ed</h4>
              <ul>
                <li>walk → <strong>walked</strong></li>
                <li>play → <strong>played</strong></li>
                <li>visit → <strong>visited</strong></li>
                <li>study → <strong>studied</strong> (y → ied)</li>
              </ul>
              <h4>Irregular verbs (must memorise)</h4>
              <ul>
                <li>go → <strong>went</strong></li>
                <li>have → <strong>had</strong></li>
                <li>do → <strong>did</strong></li>
                <li>say → <strong>said</strong></li>
                <li>see → <strong>saw</strong></li>
                <li>buy → <strong>bought</strong></li>
                <li>come → <strong>came</strong></li>
                <li>take → <strong>took</strong></li>
              </ul>
              <h4>Structure</h4>
              <ul>
                <li><strong>Positive:</strong> I <u>walked</u> to school yesterday.</li>
                <li><strong>Negative:</strong> I <u>didn't walk</u> to school yesterday.</li>
                <li><strong>Question:</strong> <u>Did</u> you <u>walk</u> to school yesterday?</li>
              </ul>
              <div class="example">
                <strong>Practice:</strong> "Last weekend, I went to the cinema. I watched a great film. I didn't eat popcorn because I had dinner before."
              </div>
            `
            }],
            quiz: [{
                question: 'What is the past simple of "go"?',
                options: ['goed', 'went', 'gone', 'going'],
                correct: 1,
                explanation: '"Went" is the past simple of "go". (Gone is the past participle.)'
            }, {
                question: '"I ___ breakfast at 7am every day." Fill the blank.',
                options: ['have', 'has', 'had', 'am having'],
                correct: 0,
                explanation: 'Use "have" for present simple with I/you/we/they.'
            }, {
                question: 'Which sentence is in the past simple?',
                options: ['I eat breakfast.', 'I ate breakfast.', 'I am eating breakfast.', 'I will eat breakfast.'],
                correct: 1,
                explanation: '"I ate" is past simple. "I eat" is present, "I am eating" is present continuous.'
            }, {
                question: 'What is the negative of "She visited Paris"?',
                options: ['She not visited Paris', 'She didn\'t visit Paris', 'She doesn\'t visit Paris', 'She didn\'t visited Paris'],
                correct: 1,
                explanation: 'Use "didn\'t" + base form: "She didn\'t visit Paris."'
            }, {
                question: '"Last year, I ___ a new car." Which is correct?',
                options: ['buy', 'bought', 'buyed', 'have bought'],
                correct: 1,
                explanation: '"Bought" is the past simple of "buy".'
